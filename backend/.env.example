# DashScope (Alibaba Cloud Bailian) - Qwen LLM API
DASHSCOPE_API_KEY=your_dashscope_api_key_here
DASHSCOPE_MODEL=qwen-plus
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# HuggingFace Token (for DermFM-Zero model download)
HF_TOKEN=your_huggingface_token_here

# DermFM-Zero model weights path (optional, defaults to ./models/dermfm/open_clip_pytorch_model.bin)
# DERMFM_MODEL_PATH=./models/dermfm/open_clip_pytorch_model.bin

# JWT Secret (MUST change in production)
# SECRET_KEY=your-random-secret-key-here

# Admin account (created on first startup if no admin exists)
# ADMIN_USERNAME=admin
# ADMIN_EMAIL=admin@dermascan.ai
# ADMIN_PASSWORD=changeme123
